rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is an admin
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }

    match /providers/{providerId} {
      // Anyone can read active providers. Only admin or the provider can edit.
      allow read: if resource.data.isApproved == true || request.auth.uid == providerId || isAdmin();
      allow write: if request.auth.uid == providerId || isAdmin();
    }

    match /bookings/{bookingId} {
      // Customers read their own; Providers read assigned; Admins read all
      allow read: if request.auth.uid == resource.data.customerId 
                  || request.auth.uid == resource.data.providerId 
                  || isAdmin();
      
      // Customers can create bookings
      allow create: if request.auth.uid == request.resource.data.customerId;
      
      // Providers can only update the status of their assigned bookings. Prevent manual price/commission tampering.
      allow update: if isAdmin() || 
                    (request.auth.uid == resource.data.providerId && 
                     request.resource.data.diff(resource.data).affectedKeys()
                     .hasOnly(['status', 'statusHistory', 'updatedAt']));
    }

    // Commission fields protected strictly for Admin
    match /commissions/{commissionId} {
      allow read, write: if isAdmin();
    }
    
    // Global metrics (read-only for non-admins)
    match /platform_stats/{statId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
